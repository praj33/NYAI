{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "types": ["@playwright/test", "node"]
  },
  "include": ["e2e/**/*.ts", "playwright.config.ts", "src/**/*.ts", "src/**/*.tsx", "src/lib/apiConfig.ts"]
}
