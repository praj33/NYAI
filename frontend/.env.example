# =============================================================================
# NYAI Frontend — Environment Template
# Copy to frontend/.env and set values. For Vercel: add in Dashboard → redeploy.
# VITE_NYAI_API_KEY must exactly match backend NYAI_API_KEY.
# =============================================================================

# Production
VITE_API_URL=https://your-backend.onrender.com
VITE_NYAI_API_KEY=your-secret-api-key-here

# Local development
# VITE_API_URL=http://localhost:8000
# VITE_NYAI_API_KEY=your-secret-api-key-here
