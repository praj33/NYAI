# =============================================================================
# NYAI Backend — Environment Template
# Copy to backend/.env and replace all REPLACE_* / your-* placeholders.
# For Render: paste KEY=VALUE pairs into Dashboard → Environment.
# =============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Production hardening (REQUIRED on live) ---
NYAI_API_KEY=your-secret-api-key-here
# If missing: CRITICAL log + all /nyaya/* return 503 AUTH_CONFIGURATION_ERROR
FRONTEND_URL=https://your-frontend.vercel.app
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# --- Groq LLM (strongly recommended on live) ---
GROQ_ENABLED=true
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=20
GROQ_DEBUG=false
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_QUERY_UNDERSTANDING_MODEL=llama-3.1-8b-instant
GROQ_QUERY_EXPANDER_MODEL=llama-3.1-8b-instant
GROQ_EXPLAINER_MODEL=llama-3.1-8b-instant
GROQ_QUERY_UNDERSTANDING_ENABLED=true
GROQ_SECTION_RERANK_ENABLED=true
GROQ_SECTION_RERANK_CANDIDATES=18

# --- Provenance / signing ---
HMAC_SECRET_KEY=change-me-in-production
SIGNING_METHOD=HMAC_SHA256
SIGNING_KEY_ID=primary-key-2026
PROVENANCE_LEDGER_PATH=provenance_ledger.json
ENFORCEMENT_LEDGER_PATH=enforcement_ledger.json

# --- Retrieval pipeline ---
HYBRID_RETRIEVER_ENABLED=true
HYBRID_RETRIEVER_TIMEOUT_SECONDS=12
RERANKER_ENABLED=true
RERANKER_TIMEOUT_SECONDS=8
SEMANTIC_SEARCH_ENABLED=false
DETERMINISM_GUARD_ENABLED=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=nyaya.log

# --- Legacy / optional ---
DATABASE_URL=sqlite:///./nyaya.db
INPUT_DIRECTORY=db
OUTPUT_DIRECTORY=output
NONCE_TTL_SECONDS=300

# --- Local development ---
# FRONTEND_URL=http://localhost:5173
