# Nyaya AI Backend Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security Configuration (CHANGE IN PRODUCTION)
HMAC_SECRET_KEY=change-me-in-production
SIGNING_METHOD=HMAC_SHA256
SIGNING_KEY_ID=primary-key-2025

# Database Configuration
DATABASE_URL=sqlite:///./nyaya.db

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=nyaya.log

# Data Bridge Configuration
INPUT_DIRECTORY=db
OUTPUT_DIRECTORY=output

# Optional Groq response generation
GROQ_ENABLED=true
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=20
GROQ_DEBUG=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Hybrid Retriever
HYBRID_RETRIEVER_ENABLED=true
HYBRID_RETRIEVER_TIMEOUT_SECONDS=12

# Reranker
RERANKER_ENABLED=true
RERANKER_TIMEOUT_SECONDS=8

# Provenance Ledger
ENFORCEMENT_LEDGER_PATH=enforcement_ledger.json
PROVENANCE_LEDGER_PATH=provenance_ledger.json
